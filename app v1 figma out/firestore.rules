# Firebase Security Rules for CCTV Security Business App

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if user has vendor role
    function isVendor() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendor';
    }
    
    // Helper function to check if user has technician role
    function isTechnician() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'technician';
    }
    
    // Users collection - users can read their own data, vendors can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isVendor());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isVendor());
      allow delete: if isAuthenticated() && isOwner(userId);
    }
    
    // Customers collection - only vendors and authorized technicians can access
    match /customers/{customerId} {
      allow read: if isAuthenticated() && (isVendor() || isTechnician());
      allow create: if isAuthenticated() && isVendor();
      allow update: if isAuthenticated() && (isVendor() || isTechnician());
      allow delete: if isAuthenticated() && isVendor();
    }
    
    // Jobs/Works collection
    match /jobs/{jobId} {
      allow read: if isAuthenticated() && (isVendor() || isTechnician());
      allow create: if isAuthenticated() && isVendor();
      allow update: if isAuthenticated() && (isVendor() || isTechnician());
      allow delete: if isAuthenticated() && isVendor();
    }
    
    // Expenses collection - vendors and technicians with expense permission
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (isVendor() || isTechnician());
      allow create: if isAuthenticated() && (isVendor() || isTechnician());
      allow update: if isAuthenticated() && isVendor();
      allow delete: if isAuthenticated() && isVendor();
    }
    
    // Billing collection
    match /bills/{billId} {
      allow read: if isAuthenticated() && (isVendor() || isTechnician());
      allow create: if isAuthenticated() && (isVendor() || isTechnician());
      allow update: if isAuthenticated() && isVendor();
      allow delete: if isAuthenticated() && isVendor();
    }
    
    // Team members collection - only vendors can manage
    match /team/{memberId} {
      allow read: if isAuthenticated() && (isVendor() || isTechnician());
      allow create: if isAuthenticated() && isVendor();
      allow update: if isAuthenticated() && isVendor();
      allow delete: if isAuthenticated() && isVendor();
    }
    
    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
